# Dockerfile for ai-hackathon server
# Optimized multi-stage build for Railway deployment

# Build stage
FROM node:20-alpine AS builder

WORKDIR /app

RUN npm install -g pnpm

# Copy workspace configuration
COPY package.json pnpm-lock.yaml* pnpm-workspace.yaml ./

# Copy all package.json files to allow pnpm to resolve the workspace
COPY apps/server/package.json ./apps/server/
COPY packages/api/package.json ./packages/api/
COPY packages/auth/package.json ./packages/auth/
COPY packages/config/package.json ./packages/config/
COPY packages/db/package.json ./packages/db/
COPY packages/env/package.json ./packages/env/
COPY packages/queue/package.json ./packages/queue/
COPY packages/shared/package.json ./packages/shared/

# Install dependencies
RUN pnpm install --frozen-lockfile

# Copy the rest of the source code
COPY . .

# Build the server and its dependencies
RUN pnpm dlx turbo run build --filter=@ai-hackathon/server...

# Production stage
FROM node:20-alpine AS runner

WORKDIR /app

RUN npm install -g pnpm

ENV NODE_ENV=production
ENV PORT=3000

# Copy built artifacts from builder
# We need the dist folder from the server
COPY --from=builder /app/apps/server/dist ./dist
COPY --from=builder /app/apps/server/package.json ./package.json

# Copy necessary workspace files for pnpm to work in production
COPY --from=builder /app/pnpm-lock.yaml* /app/pnpm-workspace.yaml /app/package.json ./

# Copy packages that are used as workspace dependencies
# Note: Since tsdown bundles dependencies, we might not need all of these, 
# but for safety with NestJS and Reflect-metadata, we'll keep the structure.
COPY --from=builder /app/packages ./packages

# Install production dependencies only
# We use --prod to skip devDependencies and --ignore-scripts if not needed
RUN pnpm install --prod --frozen-lockfile

EXPOSE 3000

# Use index.mjs as generated by tsdown
CMD ["node", "dist/index.mjs"]
