{
  "name": "ai-hackathon",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.4.1",
      "zod": "^4.3.6",
      "@types/node": "^25.5.2",
      "@trpc/server": "^11.16.0",
      "better-auth": "^1.5.6",
      "react": "^19.2.4",
      "@types/react": "^19.2.14",
      "vitest": "^4.1.2",
      "@vitest/ui": "^4.1.2",
      "@vitest/coverage-v8": "^4.1.2",
      "jsdom": "^29.0.1",
      "@trpc/client": "^11.16.0",
      "mongoose": "^9.4.1"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "test": "turbo test",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "check": "biome check --write .",
    "prepare": "pnpm dlx husky install"
  },
  "dependencies": {
    "@ai-hackathon/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@ai-hackathon/config": "workspace:*",
    "@biomejs/biome": "^2.4.10",
    "@types/node": "catalog:",
    "turbo": "^2.9.4",
    "typescript": "^6.0.2",
    "vercel": "^41.7.4",
    "husky": "^9.0.11"
  },
  "packageManager": "pnpm@9.12.2"
}
